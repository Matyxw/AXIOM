{
  "name": "AXIOM Dev Environment (Nix + Rust)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "extraNixConfig": "experimental-features = nix-command flakes\naccept-flake-config = true"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "rust-analyzer.server.path": "rust-analyzer",
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nil"
      },
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "mkhl.direnv",
        "jnoortheen.nix-ide",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "postCreateCommand": "bash -c 'sudo apt-get update && sudo apt-get install -y direnv && echo \"eval \\\"\\$(direnv hook bash)\\\"\" >> ~/.bashrc && echo \"eval \\\"\\$(direnv hook zsh)\\\"\" >> ~/.zshrc && direnv allow .'",
  "remoteUser": "vscode"
}
