#!/usr/bin/env bash
# AXIOM Pre-commit Hook
# Enforcement mecánico de las reglas del agente THE ARCHITECT.
# Instalación: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔍 [APEX Pre-commit] Auditando código..."

# ── 1. RUST: unwrap() en código de producción ─────────────────────────────────
UNWRAP_FILES=$(git diff --cached --name-only | grep '\.rs$' || true)
if [ -n "$UNWRAP_FILES" ]; then
    # Busca unwrap() fuera de bloques de test o sin comentario SAFETY
    VIOLATIONS=$(git diff --cached -- '*.rs' | grep '^\+' | grep -v '^\+\+\+' | grep '\.unwrap()' | grep -v '// SAFETY:' | grep -v '#\[cfg(test)\]' || true)
    if [ -n "$VIOLATIONS" ]; then
        echo -e "${RED}❌ [FAIL] unwrap() sin // SAFETY: en código de producción:${NC}"
        echo "$VIOLATIONS"
        echo -e "${YELLOW}→ Propagar con '?' o documentar con '// SAFETY: razón'${NC}"
        exit 1
    fi
fi

# ── 2. SECRETOS HARDCODEADOS ──────────────────────────────────────────────────
SECRET_PATTERNS='(EAAI_|sk-|ghp_|gho_|github_pat_|xoxb-|xoxp-)'
SECRETS=$(git diff --cached -- ':!*.example' | grep '^\+' | grep -v '^\+\+\+' | grep -E "$SECRET_PATTERNS" || true)
if [ -n "$SECRETS" ]; then
    echo -e "${RED}❌ [FAIL] Posible secreto hardcodeado detectado:${NC}"
    echo "$SECRETS"
    exit 1
fi

# ── 3. RUST: cargo check (solo si hay archivos .rs en el diff) ────────────────
if [ -n "$UNWRAP_FILES" ]; then
    if command -v cargo &> /dev/null; then
        echo "🦀 [cargo check] Verificando compilación..."
        if ! cargo check --quiet 2>&1; then
            echo -e "${RED}❌ [FAIL] cargo check falló. No se puede commitear código que no compila.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✅ cargo check OK${NC}"
    else
        echo -e "${YELLOW}⚠️  cargo no encontrado. Saltar dentro de 'nix develop'.${NC}"
    fi
fi

# ── 4. FRONTEND: NEXT_PUBLIC_ con posibles secretos ──────────────────────────
FRONTEND_FILES=$(git diff --cached --name-only | grep '\.tsx\?$' || true)
if [ -n "$FRONTEND_FILES" ]; then
    NEXT_PUBLIC_SECRETS=$(git diff --cached -- '*.ts' '*.tsx' | grep '^\+' | grep -v '^\+\+\+' | grep 'NEXT_PUBLIC_' | grep -iE '(key|secret|token|password|apikey)' || true)
    if [ -n "$NEXT_PUBLIC_SECRETS" ]; then
        echo -e "${RED}❌ [FAIL] NEXT_PUBLIC_ con posible secreto detectado:${NC}"
        echo "$NEXT_PUBLIC_SECRETS"
        exit 1
    fi
fi

echo -e "${GREEN}✅ [APEX Pre-commit] Todo limpio. Procediendo con el commit.${NC}"
exit 0
